// Gmail integration functions
function initializeGmailIntegration() {
    // Check if user is already signed in and has Gmail access
    const savedUser = localStorage.getItem('golfUser');
    if (savedUser) {
        currentUser = JSON.parse(savedUser);
        
        // Check if we have Gmail access
        checkGmailAccess();
    }
}

function checkGmailAccess() {
    // Check if user has granted Gmail access
    const gmailAccess = localStorage.getItem('gmailAccess');
    if (!gmailAccess) {
        // Show permission request after a short delay
        setTimeout(() => {
            showGmailPermissionRequest();
        }, 2000);
    } else {
        // User has granted access, we can search emails
        searchGolfEmails();
    }
}

function showGmailPermissionRequest() {
    // Create a modal to request Gmail access
    const modal = document.createElement('div');
    modal.className = 'modal';
    modal.style.display = 'block';
    modal.innerHTML = `
        <div class="modal-content">
            <h2>Connect Your Gmail</h2>
            <p>To automatically track your golf rounds, we need permission to search your emails for golf-related data from apps like Golfshot.</p>
            <div class="permission-features">
                <div class="feature-item">
                    <span class="feature-icon">🔍</span>
                    <span>Search for golf round emails</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">📊</span>
                    <span>Extract scores and course data</span>
                </div>
                <div class="feature-item">
                    <span class="feature-icon">🔒</span>
                    <span>Your data stays private and secure</span>
                </div>
            </div>
            <div class="permission-buttons">
                <button class="btn-primary" onclick="requestGmailAccess()">Allow Gmail Access</button>
                <button class="btn-secondary" onclick="closePermissionModal()">Skip for Now</button>
            </div>
        </div>
    `;
    document.body.appendChild(modal);
}

function requestGmailAccess() {
    // Mark that user wants Gmail access
    localStorage.setItem('gmailAccess', 'requested');
    closePermissionModal();
    
    // Show notification that Gmail access is being requested
    showNotification('Gmail access requested! Please sign in again to grant access.');
    
    // For now, use simulated data since we can't easily re-trigger OAuth
    // In a real implementation, you would redirect to OAuth with Gmail scope
    setTimeout(() => {
        simulateGolfEmailData();
        showNotification('Using sample golf data. Gmail integration will be available in the next update.');
    }, 1000);
}

async function searchGolfEmails() {
    try {
        console.log('Searching for golf emails...');
        
        // Check if your backend has the Gmail endpoint
        const response = await fetch('/api/search-golf-emails', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({
                user_id: currentUser.id
            })
        });
        
        if (response.ok) {
            const data = await response.json();
            if (data.success) {
                updateRoundsWithRealData(data.rounds);
                showNotification(`Found ${data.rounds.length} golf rounds from your emails!`);
                return;
            }
        }
        
        // If backend endpoint doesn't exist yet, simulate data
        console.log('Backend Gmail endpoint not available, using simulated data');
        simulateGolfEmailData();
        
    } catch (error) {
        console.log('Gmail search failed, using simulated data:', error);
        simulateGolfEmailData();
    }
}

function simulateGolfEmailData() {
    // Simulate finding golf emails and extracting data
    const golfRounds = [
        {
            course: "Pebble Beach Golf Links",
            score: 85,
            par: 72,
            date: "2024-03-15",
            source: "Golfshot",
            emailSubject: "Your Round at Pebble Beach Golf Links",
            rating: 75.1,
            slope: 142
        },
        {
            course: "Augusta National Golf Club", 
            score: 92,
            par: 72,
            date: "2024-03-08",
            source: "Golfshot",
            emailSubject: "Round Summary - Augusta National",
            rating: 76.2,
            slope: 148
        }
    ];
    
    // Store the extracted data
    localStorage.setItem('golfRounds', JSON.stringify(golfRounds));
    
    // Update the UI with real data
    updateRoundsWithRealData(golfRounds);
    
    showNotification(`Found ${golfRounds.length} golf rounds from your emails!`);
}

function updateRoundsWithRealData(rounds) {
    // Update the dashboard and rounds page with real data
    console.log('Updating UI with real golf data:', rounds);
    
    // Update dashboard recent rounds
    updateDashboardRounds(rounds);
    
    // Update full rounds page
    updateRoundsPage(rounds);
}

function updateDashboardRounds(rounds) {
    const roundsList = document.querySelector('.rounds-list');
    if (!roundsList) return;
    
    // Show only the 3 most recent rounds
    const recentRounds = rounds.slice(0, 3);
    
    roundsList.innerHTML = recentRounds.map(round => `
        <div class="round-item">
            <div class="round-course">${round.course}</div>
            <div class="round-score">${round.score} (+${round.score - round.par})</div>
            <div class="round-date">${formatDate(round.date)}</div>
        </div>
    `).join('');
}

function updateRoundsPage(rounds) {
    const roundsContainer = document.querySelector('.rounds-container');
    if (!roundsContainer) return;
    
    roundsContainer.innerHTML = rounds.map(round => `
        <div class="round-card">
            <div class="round-image">
                <img src="https://images.unsplash.com/photo-1535131749006-b7f58c99034b?w=400&h=250&fit=crop" alt="${round.course}">
            </div>
            <div class="round-details">
                <div class="round-header">
                    <h3>${round.course}</h3>
                    <div class="round-score">
                        <span class="score-number">${round.score}</span>
                        <span class="score-par">+${round.score - round.par}</span>
                    </div>
                </div>
                <div class="round-info">
                    <div class="course-stats">
                        <div class="stat">
                            <span class="stat-label">Rating:</span>
                            <span class="stat-value">${round.rating}</span>
                        </div>
                        <div class="stat">
                            <span class="stat-label">Slope:</span>
                            <span class="stat-value">${round.slope}</span>
                        </div>
                    </div>
                    <div class="round-meta">
                        <span class="round-date">${formatDate(round.date)}</span>
                        <span class="round-source">Source: ${round.source}</span>
                    </div>
                </div>
            </div>
        </div>
    `).join('');
}

function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toLocaleDateString('en-US', { 
        year: 'numeric', 
        month: 'long', 
        day: 'numeric' 
    });
}

function closePermissionModal() {
    const modal = document.querySelector('.modal');
    if (modal) {
        modal.remove();
    }
    
    // Mark that user skipped Gmail access
    localStorage.setItem('gmailAccess', 'skipped');
    
    // Use simulated data instead
    simulateGolfEmailData();
    showNotification('Using sample golf data. You can enable Gmail access later in settings.');
}
